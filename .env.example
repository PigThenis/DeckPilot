# Copy this file to ".env" and fill in your key, then restart `npm run dev`.
# Required only for the AI Tagging feature. Never commit your real .env.

# Your OpenAI API key (used by AI Tagging, sent via the /openai dev proxy).
VITE_OPENAI_API_KEY=

# Optional — override the model (defaults to gpt-5.4-nano-2026-03-17).
# VITE_OPENAI_MODEL=gpt-5.4-nano-2026-03-17
